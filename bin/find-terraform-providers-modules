#!/usr/bin/env zsh

# Terraform Provider and Module Version Finder
# Uses fd, gawk for fast scanning

set -euo pipefail

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

# Folders to ignore
IGNORE_FOLDERS=(
    "terraform-google-lb-http"
)

SEARCH_DIR="${1:-.}"

print -P "${BLUE}Scanning Terraform files in: ${SEARCH_DIR}${NC}\n"

# Build fd exclude arguments
FD_EXCLUDES=()
for folder in "${IGNORE_FOLDERS[@]}"; do
    FD_EXCLUDES+=(-E "$folder")
done

# Temp files
PROVIDER_RESULTS=$(mktemp)
MODULE_RESULTS=$(mktemp)
trap "rm -f $PROVIDER_RESULTS $MODULE_RESULTS" EXIT

# Find all .tf files and process for providers
fd -e tf "${FD_EXCLUDES[@]}" . "$SEARCH_DIR" -x gawk '
BEGIN { in_block = 0; in_provider = 0; provider = ""; source = ""; version = "" }

/required_providers[[:space:]]*\{/ { in_block = 1; next }

in_block && /^[[:space:]]*\}[[:space:]]*$/ && in_provider == 0 { in_block = 0; next }

in_block && /^[[:space:]]*[a-zA-Z0-9_-]+[[:space:]]*=[[:space:]]*\{/ {
    gsub(/[[:space:]]*=.*/, "", $0)
    gsub(/^[[:space:]]+/, "", $0)
    provider = $0
    in_provider = 1
    source = ""
    version = ""
    next
}

in_block && in_provider && /^[[:space:]]*\}/ {
    if (version != "") {
        if (source != "") {
            print source "\t" version "\t" FILENAME
        } else {
            print provider "\t" version "\t" FILENAME
        }
    }
    in_provider = 0
    provider = ""
    source = ""
    version = ""
    next
}

in_block && in_provider && /source[[:space:]]*=/ {
    gsub(/.*source[[:space:]]*=[[:space:]]*"/, "", $0)
    gsub(/".*/, "", $0)
    source = $0
}

in_block && in_provider && /^[[:space:]]*version[[:space:]]*=/ {
    gsub(/.*version[[:space:]]*=[[:space:]]*"/, "", $0)
    gsub(/".*/, "", $0)
    version = $0
}
' {} >> "$PROVIDER_RESULTS"

# Find all .tf files and process for modules (excluding local sources)
fd -e tf "${FD_EXCLUDES[@]}" . "$SEARCH_DIR" -x gawk '
BEGIN { in_module = 0; module_name = ""; source = ""; version = "" }

/^module[[:space:]]+"[^"]+"/ {
    in_module = 1
    gsub(/^module[[:space:]]+"|".*/, "", $0)
    module_name = $0
    source = ""
    version = ""
    next
}

in_module && /^\}/ {
    # Skip local modules (starting with ./ or ../)
    if (source != "" && source !~ /^\.\.?\//) {
        # Extract version from ref= in git URLs
        if (version == "" && match(source, /[?&]ref=([^&]+)/, arr)) {
            version = arr[1]
        }
        # Clean source: remove ?ref= and // submodule paths
        gsub(/\?ref=.*$/, "", source)
        gsub(/\/\/.*$/, "", source)
        
        if (version == "") version = "-"
        print source "\t" version "\t" FILENAME
    }
    in_module = 0
    next
}

in_module && /source[[:space:]]*=/ {
    gsub(/.*source[[:space:]]*=[[:space:]]*"/, "", $0)
    gsub(/".*/, "", $0)
    source = $0
}

# Only match "version =" at start of line (with optional whitespace), not "database_version =" etc
in_module && /^[[:space:]]*version[[:space:]]*=/ {
    gsub(/.*version[[:space:]]*=[[:space:]]*"/, "", $0)
    gsub(/".*/, "", $0)
    version = $0
}
' {} >> "$MODULE_RESULTS"

# Output providers grouped by provider+version
print -P "${GREEN}PROVIDERS${NC}"
print -P "${DIM}─────────────────────────────────────────────────────────────────────────────────────${NC}"

if [[ ! -s "$PROVIDER_RESULTS" ]]; then
    print -P "${YELLOW}No providers with versions found.${NC}"
else
    sort -u -t$'\t' -k1,3 "$PROVIDER_RESULTS" | sort -t$'\t' -k1,1 -k2,2 | gawk -F'\t' -v cyan="${CYAN}" -v green="${GREEN}" -v dim="${DIM}" -v nc="${NC}" -v search_dir="$SEARCH_DIR" '
    {
        key = $1 "\t" $2
        if (key != last_key) {
            if (last_key != "") {
                print cyan provider nc " " green version nc
                for (i = 1; i <= file_count; i++) {
                    print "  " dim files[i] nc
                }
            }
            provider = $1
            version = $2
            file_count = 0
            last_key = key
        }
        file_count++
        f = $3
        sub("^" search_dir "/", "", f)
        files[file_count] = f
    }
    END {
        if (last_key != "") {
            print cyan provider nc " " green version nc
            for (i = 1; i <= file_count; i++) {
                print "  " dim files[i] nc
            }
        }
    }
    '
fi

print ""

# Output modules grouped by source+version
print -P "${GREEN}MODULES${NC}"
print -P "${DIM}─────────────────────────────────────────────────────────────────────────────────────${NC}"

if [[ ! -s "$MODULE_RESULTS" ]]; then
    print -P "${YELLOW}No remote modules found.${NC}"
else
    sort -u -t$'\t' -k1,3 "$MODULE_RESULTS" | sort -t$'\t' -k1,1 -k2,2 | gawk -F'\t' -v cyan="${CYAN}" -v green="${GREEN}" -v dim="${DIM}" -v nc="${NC}" -v search_dir="$SEARCH_DIR" '
    {
        key = $1 "\t" $2
        if (key != last_key) {
            if (last_key != "") {
                print cyan source nc " " green version nc
                for (i = 1; i <= file_count; i++) {
                    print "  " dim files[i] nc
                }
            }
            source = $1
            version = $2
            file_count = 0
            last_key = key
        }
        file_count++
        f = $3
        sub("^" search_dir "/", "", f)
        files[file_count] = f
    }
    END {
        if (last_key != "") {
            print cyan source nc " " green version nc
            for (i = 1; i <= file_count; i++) {
                print "  " dim files[i] nc
            }
        }
    }
    '
fi

print -P "\n${BLUE}Done.${NC}"
