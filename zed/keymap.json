// from the command palette.
[
  {
    "bindings": {
      "cmd-enter": "workspace::ToggleZoom"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-§": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  }
]
