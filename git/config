[user]
	name = Benedikt Böhm
	email = bb@xnull.de
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIO2wbcnPz2sPIU1T2FFt88ZHpOXvFqwNxNX+5WFo2A2b

[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[alias]
	aliases = !git config --get-regexp 'alias.*' | colrm 1 6 | sed 's/[ ]/ = /'
	amend = ci --amend --reuse-message=HEAD
	b = !git --no-pager log --decorate --format="%D" -1
	ci = commit
	co = checkout
	dc = diff --cached
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	ls = ls-tree -r HEAD
	st = status --short
	stat = diff --stat
	tags = tag -l
	w = !git --no-pager show -s --pretty='tformat:%h %ad %s' --date=short

[advice]
	detachedHead = false

[branch]
	sort = -committerdate

[color]
	ui = true

[commit]
	gpgsign = true

[diff]
	renames = copies

[init]
	defaultBranch = main

[pull]
	ff = only

[push]
	followTags = true
	autoSetupRemote = true

[rerere]
	enabled = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
