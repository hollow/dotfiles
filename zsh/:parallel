#!zsh

local dirs=(${argv:1:((${argv[(Ie)do]}-1))})
local cmd=(${argv:((${argv[(Ie)do]}+1))})

# Burst the zi scheduler so the turbo hooks (aliases, functions, PATH) load
# despite the subshell never reaching an interactive prompt.
parallel --jobs 5 --color --tag \
    "source ${ZDOTDIR}/.zshrc; @zi-scheduler burst; pushd {} &>/dev/null; eval '${cmd[*]}'" \
    ::: "${dirs[@]}"
