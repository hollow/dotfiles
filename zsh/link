#!zsh

zmodload -F zsh/stat b:zstat

local source="$1"
local target="$2"

if [[ "${source}" == "" ]]; then
    print -P "usage: %N <source> [<target>]"
    return 1
fi

if [[ "${target}" == "" ]]; then
    target="${source}"
fi

if [[ "${source}" != '/'* ]]; then
    source="${XDG_CONFIG_HOME}/${source}"
fi

if [[ "${target}" != '/'* ]]; then
    target="${HOME}/${target}"
fi

# read the current symlink target without forking readlink (zstat -L +link is
# lstat, so it reports the link itself, not what it resolves to); relink only
# when missing or pointing elsewhere, so a warm shell forks nothing here
local -a st
zstat -A st -L +link -- "${target}" 2>/dev/null
if [[ "${st[1]}" != "${source}" ]]; then
    ln -nfs "${source}" "${target}"
fi
