{
	"inputs": [
		{
			"id": "tfe_token",
			"type": "promptString",
			"description": "Terraform API Token",
			"password": true
		},
		{
			"id": "tfe_hostname",
			"type": "promptString",
			"description": "Terraform hostname",
			"password": false
		}
