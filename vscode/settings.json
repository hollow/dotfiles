{
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[go]": {
		"editor.codeActionsOnSave": {
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "golang.go"
	},
	"[hcl]": {
		"editor.defaultFormatter": "fredwangwang.vscode-hcl-format"
	},
	"[html]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[ignore]": {
		"editor.formatOnSave": false
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[markdown]": {
		"editor.defaultFormatter": "rvben.rumdl"
	},
	"[opentofu-vars]": {
		"editor.defaultFormatter": "opentofu.vscode-opentofu"
	},
	"[opentofu]": {
		"editor.defaultFormatter": "opentofu.vscode-opentofu"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff"
	},
	"[ruby]": {
		"editor.defaultFormatter": "Shopify.ruby-lsp"
	},
	"[shellscript]": {
		"editor.defaultFormatter": "mkhl.shfmt"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"catppuccin.italicKeywords": false,
	"csv-preview.resizeColumns": "all",
	"editor.codeActionsOnSave": {
		"quickfix.biome": "explicit",
		"source.fixAll.ruff": "explicit",
		"source.fixAll.rumdl": "explicit",
		"source.fixAll.shellcheck": "explicit",
		"source.formatAll.opentofu": "explicit",
		"source.organizeImports.biome": "explicit",
		"source.organizeImports.ruff": "explicit"
	},
	"editor.fontFamily": "'MesloLGS Nerd Font', Menlo, Monaco, 'Courier New', monospace",
	"editor.formatOnSave": true,
	"editor.minimap.enabled": false,
	"editor.showFoldingControls": "always",
	"editor.wordWrap": "on",
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"go.useLanguageServer": true,
	"gopls": {
		"formatting.gofumpt": true
	},
	"json.schemaDownload.trustedDomains": {
		"https://biomejs.dev": true,
		"https://developer.microsoft.com/json-schemas/": true,
		"https://json-schema.org/": true,
		"https://json.schemastore.org/": true,
		"https://raw.githubusercontent.com/devcontainers/spec/": true,
		"https://raw.githubusercontent.com/microsoft/vscode/": true,
		"https://schemastore.azurewebsites.net/": true,
		"https://www.schemastore.org/": true
	},
	"markdown.extension.toc.levels": "2..6",
	"mise.checkForNewMiseVersion": false,
	"redhat.telemetry.enabled": false,
	"search.followSymlinks": false,
	"search.showLineNumbers": true,
	"terminal.integrated.initialHint": false,
	"terminal.integrated.scrollback": 10000,
	"terminal.integrated.shellIntegration.decorationsEnabled": "never",
	"terminal.integrated.stickyScroll.enabled": false,
	"terminal.integrated.suggest.enabled": false,
	"workbench.colorTheme": "Catppuccin Mocha",
	"workbench.iconTheme": "catppuccin-mocha"
}
